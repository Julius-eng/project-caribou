	(text "CMAIN 12V redundancy power input — 3x LTC4370 dual-input current-sharing stages"
		(at 12.70 12.70 0)
		(effects (font (size 1.5 1.5)) (justify left))
		(uuid "9ed0518b-b590-42b9-b720-dc0376711e7b")
	)
	(text "Topology: CBC1+CBC4 -> 12V_CH1, CBC2+CBC5 -> 12V_CH2, CBC3+CBC6 -> 12V_CH3. Each input path has fuse/eFuse placeholder, N-MOSFET, 2.5mΩ sense resistor, and LTC4370 support parts."
		(at 12.70 19.05 0)
		(effects (font (size 1.05 1.05)) (justify left))
		(uuid "7c6cccb9-54a0-4d0e-a3a8-b5d2388b5851")
	)
